# .env.authentik.example
#
# Copy to .env.authentik and generate real secrets before starting:
#
#   cp .env.authentik.example .env.authentik
#   openssl rand -base64 36 | tr -d '\n' | pbcopy   # paste as PG_PASS
#   openssl rand -base64 60 | tr -d '\n' | pbcopy   # paste as AUTHENTIK_SECRET_KEY
#
# Then:
#   docker compose -f docker-compose.authentik.yml --env-file .env.authentik up -d

# PostgreSQL password (max 99 chars due to PG limitation)
PG_PASS=CHANGE_ME_generate_with_openssl

# Authentik Django secret key
AUTHENTIK_SECRET_KEY=CHANGE_ME_generate_with_openssl

# PostgreSQL user/database (defaults are fine for local testing)
# PG_USER=authentik
# PG_DB=authentik

# Authentik image tag (pin to a specific version if needed)
# AUTHENTIK_TAG=2025.4.4

# Host ports (change if 9000/9443 are already in use)
# COMPOSE_PORT_HTTP=9000
# COMPOSE_PORT_HTTPS=9443
