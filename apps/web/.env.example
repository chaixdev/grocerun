# Database connection string
# For SQLite: file:./dev.db (dev) or file:/app/data/prod.db (prod)
DATABASE_URL=file:./dev.db

# OIDC Issuer URI
# Google (default): https://accounts.google.com
# Authentik (local smoke test): http://localhost:9000/application/o/grocerun/
# Other providers: check your IdP's .well-known/openid-configuration
VITE_OIDC_ISSUER_URI=https://accounts.google.com

# OIDC Client ID (from your provider)
VITE_OIDC_CLIENT_ID=YOUR_CLIENT_ID_HERE

# OIDC Client Secret — Google only!
# Required for Google (requires client_secret even with PKCE).
# NOT needed for standard OIDC providers (Authentik, Keycloak, etc.).
# Note: This is a public client — the secret is visible in the browser bundle.
# This is a Google-specific limitation documented in the auth rules.
VITE_OIDC_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Production runtime OIDC config (set at container start, NOT build time):
#   OIDC_CLIENT_ID=YOUR_CLIENT_ID_HERE
#   OIDC_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE  # Google only
#   OIDC_ISSUER_URI=https://accounts.google.com
#   OIDC_AUDIENCE=YOUR_CLIENT_ID_HERE
#   OIDC_PROVIDER=google  # or authentik, keycloak, etc.

# NestJS API URL (server-side only — no NEXT_PUBLIC_ prefix needed)
API_URL=http://localhost:3001

# Hostname to bind to (default: 0.0.0.0)
HOSTNAME=0.0.0.0

# Docker image version tag (default: latest)
GROCERUN_VERSION=latest

# Invitation Configuration (optional, default is 1440 minutes)
INVITATION_TIMEOUT_MINUTES=1440
