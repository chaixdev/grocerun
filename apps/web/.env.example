# Database connection string
# For SQLite: file:./dev.db (dev) or file:/app/data/prod.db (prod)
DATABASE_URL=file:./dev.db

# NextAuth Secret
# Generate with: openssl rand -base64 32
AUTH_SECRET=YOUR_AUTH_SECRET_HERE

# Base URL
AUTH_URL=http://localhost:3000

# Trust host header (needed for auth() in dev/Turbopack)
AUTH_TRUST_HOST=true

# Google OAuth
AUTH_GOOGLE_ID=YOUR_GOOGLE_ID_HERE
AUTH_GOOGLE_SECRET=YOUR_GOOGLE_SECRET_HERE

# NestJS API URL (Phase 2 migration)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Hostname to bind to (default: 0.0.0.0)
HOSTNAME=0.0.0.0

# Docker image version tag (default: latest)
GROCERUN_VERSION=latest

# Invitation Configuration (optional, default is 1440 minutes)
INVITATION_TIMEOUT_MINUTES=1440
