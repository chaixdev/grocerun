# Database connection string
# For SQLite: file:./dev.db (dev) or file:/app/data/prod.db (prod)
DATABASE_URL=file:./dev.db

# Google OAuth 2.0 Client ID (OIDC)
# Create at https://console.cloud.google.com/apis/credentials
VITE_OIDC_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Google OAuth 2.0 Client Secret
# Required for Google OIDC token exchange (Google requires client_secret even with PKCE).
# Note: This is a public client — the secret is visible in the browser bundle.
# This is a known limitation documented in the Google-only auth setup.
VITE_OIDC_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Production runtime OIDC config (set at container start, NOT build time):
#   OIDC_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
#   OIDC_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
#   OIDC_AUDIENCE=YOUR_GOOGLE_CLIENT_ID_HERE

# NestJS API URL (server-side only — no NEXT_PUBLIC_ prefix needed)
API_URL=http://localhost:3001

# Hostname to bind to (default: 0.0.0.0)
HOSTNAME=0.0.0.0

# Docker image version tag (default: latest)
GROCERUN_VERSION=latest

# Invitation Configuration (optional, default is 1440 minutes)
INVITATION_TIMEOUT_MINUTES=1440
