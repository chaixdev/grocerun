    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs-zod": "^5.2.1",
