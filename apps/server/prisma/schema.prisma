// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String       @id @default(cuid())
  name               String?
  email              String?      @unique
  emailVerified      DateTime?
  image              String?
  accounts           Account[]
  sessions           Session[]
  households         Household[]
  ownedHouseholds    Household[]  @relation("HouseholdOwner")
  invitationsCreated Invitation[]
}

model Household {
  id          String       @id @default(cuid())
  name        String
  users       User[]
  stores      Store[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deleted     Boolean      @default(false)
  deletedAt   DateTime?
  ownerId     String
  owner       User         @relation("HouseholdOwner", fields: [ownerId], references: [id])
  invitations Invitation[]

  @@index([ownerId])
  @@index([updatedAt, id])
}

model Store {
  id          String    @id @default(cuid())
  name        String
  location    String?
  imageUrl    String?
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deleted     Boolean   @default(false)
  deletedAt   DateTime?
  sections    Section[]
  items       Item[]
  lists       List[]

  @@index([householdId])
  @@index([updatedAt, id])
}

model Section {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deleted   Boolean  @default(false)
  deletedAt DateTime?
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items     Item[]

  @@index([storeId])
  @@index([updatedAt, id])
}

model Item {
  id            String     @id @default(cuid())
  name          String
  storeId       String
  store         Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sectionId     String?
  section       Section?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deleted       Boolean    @default(false)
  deletedAt     DateTime?
  purchaseCount Int        @default(0)
  lastPurchased DateTime?
  defaultUnit   String?
  note          String?
  listItems     ListItem[]

  @@unique([storeId, name, deleted])
  @@index([storeId])
  @@index([sectionId])
  @@index([purchaseCount])
  @@index([storeId, purchaseCount])
  @@index([updatedAt, id])
}

model List {
  id         String     @id @default(cuid())
  name       String     @default("Shopping List")
  storeId    String
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status     ListStatus @default(PLANNING)
  assignedTo String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deleted    Boolean    @default(false)
  deletedAt  DateTime?
  items      ListItem[]

  @@index([storeId])
  @@index([status])
  @@index([storeId, status])
  @@index([updatedAt, id])
}

enum ListStatus {
  PLANNING
  SHOPPING
  COMPLETED
}

model ListItem {
  id                String   @id @default(cuid())
  listId            String
  list              List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  itemId            String
  item              Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  isChecked         Boolean  @default(false)
  quantity          Float    @default(1)
  unit              String?
  purchasedQuantity Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deleted           Boolean  @default(false)
  deletedAt         DateTime?

  @@unique([listId, itemId, deleted])
  @@index([listId])
  @@index([itemId])
  @@index([isChecked])
  @@index([listId, isChecked])
  @@index([updatedAt, id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Invitation uses a status lifecycle (ACTIVE → COMPLETED/EXPIRED/REVOKED)
// instead of soft-delete. Unlike domain models, invitations have a finite
// lifecycle with explicit terminal states — a `deleted` column would be
// redundant with `status IN ('EXPIRED', 'REVOKED')`.
model Invitation {
  id          String           @id @default(cuid())
  token       String           @unique
  householdId String
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  creatorId   String
  creator     User             @relation(fields: [creatorId], references: [id])
  status      InvitationStatus @default(ACTIVE)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([token])
}

enum InvitationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  REVOKED
}
