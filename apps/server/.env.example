# Database (Phase 2: point to web app's database)
DATABASE_URL=file:../web/dev.db

# OIDC Issuer URI
# Google (default): https://accounts.google.com
# Authentik (local smoke test): http://localhost:9000/application/o/grocerun/
# Other providers: check your IdP's .well-known/openid-configuration
OIDC_ISSUER_URI=https://accounts.google.com

# OIDC Audience — must equal the OIDC client ID (same value as VITE_OIDC_CLIENT_ID)
# Required in production. When unset in development, audience validation is skipped.
OIDC_AUDIENCE=YOUR_CLIENT_ID_HERE

# OIDC Provider name — used for Account records (default: google)
# Set to 'authentik', 'keycloak', etc. when using a non-Google provider
# OIDC_PROVIDER=google

# Server Port
PORT=3001
