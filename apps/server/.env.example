# Database (Phase 2: point to web app's database)
DATABASE_URL=file:../web/dev.db

# OIDC Issuer — currently Google-only
OIDC_ISSUER_URI=https://accounts.google.com

# OIDC Audience — must equal the Google OAuth client ID (same value as VITE_OIDC_CLIENT_ID)
# Required in production. When unset in development, audience validation is skipped.
OIDC_AUDIENCE=YOUR_GOOGLE_CLIENT_ID_HERE

# Server Port
PORT=3001
